{
  "name": "@ferie/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup src/index.ts --format esm --config tsup.config.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-ses": "^3.1030.0",
    "@ferie/shared": "workspace:*",
    "@prisma/client": "^6.19.0",
    "cors": "^2.8.5",
    "csv-parse": "^5.6.0",
    "dotenv": "^16.4.0",
    "express": "^4.21.0",
    "express-jwt": "^8.5.0",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.1.0",
    "jwks-rsa": "^3.2.0",
    "multer": "^2.1.1",
    "node-cron": "^4.2.1",
    "pg-boss": "^10.4.2",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "read-excel-file": "^9.3.3",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.0",
    "@types/express": "^5.0.0",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.5.0",
    "@types/supertest": "^7.2.0",
    "pino-pretty": "^13.1.3",
    "prisma": "^6.19.0",
    "supertest": "^7.2.2",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.2"
  }
}
