{
  "name": "itatti-ferie-portal",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm --parallel --filter @ferie/server --filter @ferie/web dev",
    "dev:server": "pnpm --filter @ferie/server dev",
    "dev:web": "pnpm --filter @ferie/web dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "db:generate": "pnpm --filter @ferie/server db:generate",
    "db:migrate": "pnpm --filter @ferie/server db:migrate",
    "db:deploy": "pnpm --filter @ferie/server db:deploy",
    "db:seed": "pnpm --filter @ferie/server db:seed",
    "dev:db": "docker compose -f docker-compose.dev.yml up -d",
    "dev:setup": "pnpm install && pnpm dev:db && pnpm db:deploy && pnpm db:seed"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.32.1",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "esbuild",
      "prisma"
    ]
  }
}
